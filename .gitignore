# Generated verdicts may contain sensitive user evidence.
verdicts/*
!verdicts/.gitkeep

# Private machine-readable ledgers may contain sensitive user evidence.
ledgers/*
!ledgers/.gitkeep

# Local environment and secrets.
.env
.env.*
*.pem
*.key
*.token

# Editor and OS noise.
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs and temporary files.
*.log
*.pyc
__pycache__/
tmp/
.tmp/
